# Copy to .env and fill in your values.

# Required — powers the RAG engine
OPENAI_API_KEY=your_openai_api_key_here

# Optional — model override (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# Optional — Flask session secret (a safe default is used for local runs)
# SECRET_KEY=change-me

# Optional — auto-login a demo account for local exploration (never in production)
# DEMO_MODE=1

# Optional — Stripe billing (subscription flow stays disabled without these)
# STRIPE_API_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID=price_...
